# Configuración básica de Django
SECRET_KEY=tu_secret_key_aqui
DEBUG=True
ALLOWED_HOSTS=127.0.0.1,localhost

# Configuración de Base de Datos (MySQL)
DATABASE_NAME=nombre_de_tu_db
DATABASE_USR=tu_usuario
DATABASE_PWD=tu_password
DATABASE_HOST=127.0.0.1
DATABASE_PORT=3306

# Configuración de Email (Mailtrap u otro SMTP)
EMAIL_HOST=sandbox.smtp.mailtrap.io
EMAIL_HOST_USER=tu_usuario_de_mailtrap
EMAIL_HOST_PASSWORD=tu_password_de_mailtrap
EMAIL_PORT=2525

# Configuración de PayPal
PAYPAL_TEST=True
PAYPAL_USER_EMAIL=tu_email_de_negocios_sandbox@example.com

# Otros
ADMIN_USER_EMAIL=admin@example.com